# FramePro Environment Variables Template
# Copy this file to .env and adjust values for your environment.

# General App Settings
PROJECT_NAME="FramePro API"
VERSION="1.0.0"
API_V1_STR="/v1"

# Security & Authentication Credentials
SECRET_KEY="change-this-to-a-secure-random-secret-in-production"
JWT_SECRET_KEY="change-this-jwt-secret-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Admin Panel Credentials
ADMIN_DEFAULT_EMAIL="admin@framepro.com"
ADMIN_DEFAULT_PASSWORD="admin-secure-pass-2026!"
ADMIN_API_KEY="framepro-admin-key-9f8e7d6c"

# Database & Cache Credentials
# Development (SQLite in-memory): sqlite+aiosqlite:///:memory:
# Production (PostgreSQL): postgresql+asyncpg://user:password@localhost:5432/framepro
DATABASE_URL="sqlite+aiosqlite:///:memory:"
REDIS_URL="redis://localhost:6379/0"

# Cloud Storage (Cloudflare R2) Credentials
R2_BUCKET="framepro-assets"
R2_ENDPOINT="https://r2.cloudflare.com"
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# AI Provider API Keys
GEMINI_API_KEY=""
OPENAI_API_KEY=""
CLAUDE_API_KEY=""

# Frontend Configuration
NEXT_PUBLIC_API_URL="http://localhost:8000"
