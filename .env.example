# FramePro Environment Variables Template
# Copy this file to .env and adjust values for your environment.

# General App Settings
PROJECT_NAME="FramePro API"
VERSION="1.0.0"
API_V1_STR="/v1"

# Security & Authentication
SECRET_KEY="change-this-to-a-secure-random-secret-in-production"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database & Cache
# Development (SQLite in-memory): sqlite+aiosqlite:///:memory:
# Production (PostgreSQL): postgresql+asyncpg://user:password@localhost:5432/framepro
DATABASE_URL="sqlite+aiosqlite:///:memory:"
REDIS_URL="redis://localhost:6379/0"

# Cloud Storage (Cloudflare R2)
R2_BUCKET="framepro-assets"
R2_ENDPOINT="https://r2.cloudflare.com"

# AI Provider API Keys
GEMINI_API_KEY=""
OPENAI_API_KEY=""
CLAUDE_API_KEY=""

# Frontend Configuration
NEXT_PUBLIC_API_URL="http://localhost:8000"
